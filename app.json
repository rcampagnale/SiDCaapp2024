{
  "expo": {
    "name": "SiDCa - Tu Sindicato",
    "slug": "sidca",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/logos/logo-05.png",
    "scheme": "sidca",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logos/logo-01.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.jakiro12.one",
      "versionCode": 19,
      "adaptiveIcon": {
        "foregroundImage": "./assets/apk.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "sidca",
              "host": "asistencia"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jakiro12.one",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Se utiliza para escanear el código QR de asistencia y permitir tomar fotos cuando se adjunta documentación.",
        "NSPhotoLibraryUsageDescription": "Se utiliza para seleccionar archivos o imágenes al completar formularios institucionales.",
        "NSPhotoLibraryAddUsageDescription": "Se utiliza para guardar o adjuntar documentación desde el dispositivo."
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Permitir que SiDCa use el micrófono.",
          "speechRecognitionPermission": "Permitir que SiDCa convierta voz en texto.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "4914455f-9037-4d80-b27c-ca5ac02ba57a"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "rcampagnale"
  }
}